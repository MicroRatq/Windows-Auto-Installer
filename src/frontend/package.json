{
  "name": "windows-auto-installer",
  "version": "0.1.0",
  "description": "Windows系统自动安装和配置工具",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k -n VITE,ELECTRON -c green,blue \"npm:dev\" \"npm:electron:wait\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron:wait": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "electron-builder"
  },
  "keywords": [
    "windows",
    "installer",
    "electron",
    "vue"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@fluentui/web-components": "^2.5.17",
    "i18next": "^23.7.0",
    "i18next-browser-languagedetector": "^7.2.0"
  }
}
